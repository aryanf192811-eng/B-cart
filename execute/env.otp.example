# ─────────────────────────────────────────────────────────────
# B-CART OTP — ENVIRONMENT VARIABLES
# ─────────────────────────────────────────────────────────────
# Copy the variables below into your existing .env file.
# DO NOT replace your .env — only ADD these new variables.
# ─────────────────────────────────────────────────────────────

# ── OTP Configuration ──────────────────────────────────────
OTP_EXPIRY_MINUTES=10
APP_NAME=B-Cart

# ── SMS Provider ────────────────────────────────────────────
# Options: console | msg91 | twilio
# Use 'console' for hackathon — OTP will print to terminal
SMS_PROVIDER=console

# ── MSG91 (India — uncomment when ready for production) ────
# MSG91_AUTH_KEY=your_msg91_auth_key_here
# MSG91_TEMPLATE_ID=your_approved_template_id
# MSG91_SENDER_ID=BCART

# ── Twilio (Global — uncomment when ready for production) ──
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_FROM_NUMBER=+1234567890

# ─────────────────────────────────────────────────────────────
# NOTHING ELSE CHANGES — your existing variables stay intact
# DATABASE_URL, JWT_SECRET, PORT etc. are untouched
# ─────────────────────────────────────────────────────────────
